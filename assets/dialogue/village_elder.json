{
  "id": "village_elder",
  "start": "intro",
  "nodes": {
    "intro": {
      "speaker": "마을 어르신",
      "text": "어디서 왔는가, 젊은이? 마침 잘 왔네.",
      "actions": [
        {
          "type": "start_quest",
          "quest": "first_meet_villager"
        }
      ],
      "choices": [
        {
          "text": "한양에서 왔소.",
          "next": "from_hanyang"
        },
        {
          "text": "그저 떠도는 길손이외다.",
          "next": "wanderer"
        },
        {
          "text": "호환 두령은 어찌 됐습니까?",
          "next": "tiger_status",
          "if_quest_active": "main_tiger_lord"
        },
        {
          "text": "(어금니를 내민다) 두령을 처치하였소.",
          "next": "tooth_show",
          "if_quest_stage": "main_tiger_lord:boss_defeated"
        },
        {
          "text": "(들판에서 주운 낡은 서찰을 내민다.)",
          "next": "scroll_show",
          "if_has_item": "scroll_old"
        }
      ]
    },
    "from_hanyang": {
      "speaker": "마을 어르신",
      "text": "오, 한양이라! 무슨 일로 이 시골까지 오셨는가?",
      "next": "outro_first"
    },
    "wanderer": {
      "speaker": "마을 어르신",
      "text": "허허, 무사인가? 칼이 가볍지 아니한가.",
      "next": "outro_first"
    },
    "outro_first": {
      "speaker": "마을 어르신",
      "text": "어쨌든 마을에 오신 것을 환영하네. (작은 답례라며 쌀떡 한 묶음을 건넨다.)",
      "actions": [
        {
          "type": "set_flag",
          "key": "talked_to_villager",
          "value": true
        },
        {
          "type": "complete_quest",
          "quest": "first_meet_villager"
        }
      ],
      "next": "tiger_offer"
    },
    "tiger_offer": {
      "speaker": "마을 어르신",
      "text": "한데… 마을이 요즘 큰일이라네. 호환(虎患)이 마을 가축을 줄줄이 잡아가는데, 두령 격인 큼지막한 놈이 있다더군.",
      "choices": [
        {
          "text": "내가 처치해 보겠소.",
          "next": "tiger_accept"
        },
        {
          "text": "(눈치를 살피며 거리를 둔다.)",
          "next": "tiger_decline"
        }
      ]
    },
    "tiger_accept": {
      "speaker": "마을 어르신",
      "text": "고맙네… 허나 조심하게. 그 범은 보통 짐승이 아니야. 자네 아버지를 알아볼지도 모르니.",
      "actions": [
        {
          "type": "start_quest",
          "quest": "main_tiger_lord"
        }
      ],
      "next": null
    },
    "tiger_decline": {
      "speaker": "마을 어르신",
      "text": "허허… 무리 마시게. 천천히 마음의 준비가 서거든 다시 오게나.",
      "next": null
    },
    "tiger_status": {
      "speaker": "마을 어르신",
      "text": "두령이 궁금하신가? 보통 범이 아닐세. 눈빛이 꼭 사람 같다는 이들이 있어… 달 없는 밤이면 사당 터 쪽에서 운다네. 들판 너머 숲, 그 끝 절벽일세.",
      "next": null
    },
    "tooth_show": {
      "speaker": "마을 어르신",
      "text": "…그 어금니. 그리고 그 환도. 자네, 무당 단의 아들이구먼. 스무 해 만에 돌아왔어.",
      "actions": [
        {
          "type": "set_quest_stage",
          "quest": "main_tiger_lord",
          "stage": "return_to_elder"
        },
        {
          "type": "complete_quest",
          "quest": "main_tiger_lord"
        },
        {
          "type": "set_flag",
          "key": "tiger_lord_resolved",
          "value": true
        }
      ],
      "next": "confession"
    },
    "scroll_show": {
      "speaker": "마을 어르신",
      "text": "허, 이게… 옛 관아의 서찰이로구먼. 잘 봐 두었네. 수고 했어. 자, 엽전 한 꾸러미 받게.",
      "actions": [
        {
          "type": "start_quest",
          "quest": "side_lost_scroll"
        },
        {
          "type": "take_item",
          "item": "scroll_old",
          "count": 1
        },
        {
          "type": "complete_quest",
          "quest": "side_lost_scroll"
        }
      ],
      "next": null
    },
    "confession": {
      "speaker": "마을 어르신",
      "text": "숨겨 미안하네. 그 흉년에 우리는 산신당을 헐어 곳간을 지었네. 당에 매인 늙은 범이 그날 밤 불 속에서 울부짖었지. 자네 아비 단은 범을 다시 달래려 불길에 뛰어들었고… 돌아오지 못했네.",
      "next": "confession2"
    },
    "confession2": {
      "speaker": "마을 어르신",
      "text": "우리는 두려워 그이를 '미친 무당'으로 적고 죄를 덮었네. 허나… 들리는가? 산울음이 잦아들지 않아. 두령은 시작일 뿐, 신산의 산신(山君)이 진노했다는 게야. 고을도, 다른 마을도 같은 화를 입고 있네.",
      "actions": [
        {
          "type": "set_flag",
          "key": "tiger_lord_resolved",
          "value": true
        },
        {
          "type": "set_flag",
          "key": "act2_open",
          "value": true
        },
        {
          "type": "start_quest",
          "quest": "main_great_tiger"
        },
        {
          "type": "change_scene",
          "scene": "res://scenes/levels/TownMarket.tscn"
        }
      ],
      "next": null
    }
  }
}