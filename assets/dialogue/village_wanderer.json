    "intro": {
      "speaker": "떠돌이 상인",
      "text": "달 뜨면 나타나는 게 우리 같은 사람들 일이지요. 야시장 구경 한번 하시겠소?",
      "choices": [
        {
          "text": "보여 주시오.",
          "next": "open"
        },
        {
          "text": "호귀에 대해 아는 게 있소?",
          "next": "wanderer_lore",
          "unless_flag": "tiger_lord_resolved"
        },
        {
          "text": "이제 어디로 가시오?",
          "next": "wanderer_leave",
          "if_flag": "tiger_lord_resolved"
        },
        {
          "text": "다음에 들르겠소.",
          "next": "later"
        }
      ]
    },
    "open": {
      "speaker": "떠돌이 상인",
      "text": "그럼 자, 우리 물건들이오.",
      "actions": [
        {
          "type": "open_shop",
          "title": "야시장",
          "items": [
