# Godot 4+ specific (표준: 4.6.3 — *.uid/*.import 사이드카는 커밋한다)
.godot/
export.cfg
# export_presets.cfg 은 의도적으로 커밋 — GitHub Actions Web export 가 사용.
# (서명/암호화 키 없이 Web preset 만 정의.)

# Android export
/android/

# Imported translations (auto-generated)
*.translation

# Build output (선택 — 빌드 산출물을 레포에 안 두려면 유지)
/builds/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log

# 스크린샷 산출물 (검증용 로컬 아티팩트)
/shots/

# PixelLab 다운로드 임시 캐시 (integrate 스크립트 작업 디렉터리)
.pl_tmp/

# Python
__pycache__/
*.pyc
