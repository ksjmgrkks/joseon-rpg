Inventory="*res://scripts/inventory/inventory_manager.gd"
Equipment="*res://scripts/inventory/equipment_manager.gd"
TimeManager="*res://scripts/world/time_manager.gd"
WorldTint="*res://scripts/world/world_tint.gd"
InkWash="*res://scripts/world/ink_wash.gd"
SpriteDb="*res://scripts/visual/sprite_db.gd"
BgmDirector="*res://scripts/audio/bgm_director.gd"
SkillManager="*res://scripts/skills/skill_manager.gd"
InputConfig="*res://scripts/input/input_config.gd"
Locale="*res://scripts/locale/locale_manager.gd"
QuestManager="*res://scripts/quests/quest_manager.gd"
ShopManager="*res://scripts/shop/shop_manager.gd"
Dialogue="*res://scripts/dialogue/dialogue_manager.gd"
DialogueBalloon="*res://scenes/ui/DialogueBalloon.tscn"
InventoryPanel="*res://scenes/ui/InventoryPanel.tscn"
ShopPanel="*res://scenes/ui/ShopPanel.tscn"
PauseMenu="*res://scenes/ui/PauseMenu.tscn"
QuestLog="*res://scenes/ui/QuestLog.tscn"
QuestToast="*res://scenes/ui/QuestToast.tscn"
GameOverScreen="*res://scenes/ui/GameOverScreen.tscn"

