; Engine configuration file.
; HANDOFF.md 기준 — Godot 4.x · GDScript 전용 · GL Compatibility(모바일·웹 호환).
; 픽셀아트라서 default_texture_filter = 0(Nearest).

config_version=5

[application]

config/name="조선시대 도트 RPG"
