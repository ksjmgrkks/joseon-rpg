[gd_scene load_steps=15 format=3]

; 호환 두령 보스 아레나 — 숲 깊은 곳. 좌측만 통로 있음(귀환), 우측은 막다른 절벽.
; 메인 퀘스트 단계 boss_arena 자동 진행.

[ext_resource type="PackedScene" path="res://scenes/player/Player.tscn" id="1_player"]
[ext_resource type="PackedScene" path="res://scenes/enemies/BossTiger.tscn" id="2_boss"]
[ext_resource type="PackedScene" path="res://scenes/ui/MobileControls.tscn" id="3_mobile"]
[ext_resource type="PackedScene" path="res://scenes/ui/PlayerHud.tscn" id="4_hud"]
[ext_resource type="Script" path="res://scripts/scene/level_exit.gd" id="5_exit"]
[ext_resource type="Script" path="res://scripts/scene/level_entry.gd" id="6_entry"]
[ext_resource type="Script" path="res://scripts/quests/quest_trigger.gd" id="7_trigger"]
[ext_resource type="Script" path="res://scripts/world/auto_dialogue.gd" id="8_autodlg"]
[ext_resource type="PackedScene" path="res://scenes/world/Backdrop.tscn" id="bd"]
[ext_resource type="Script" path="res://scripts/world/tiled_sprite.gd" id="tile"]
[ext_resource type="Texture2D" path="res://assets/tilesets/pine.png" id="pine"]

[sub_resource type="RectangleShape2D" id="RectangleShape2D_ground"]
size = Vector2(1600, 32)

[sub_resource type="RectangleShape2D" id="RectangleShape2D_exit"]
size = Vector2(32, 96)

[sub_resource type="RectangleShape2D" id="RectangleShape2D_trigger"]
size = Vector2(96, 96)

[node name="BossArena" type="Node2D"]

; 어두운 절벽 톤
[node name="Backdrop" parent="." instance=ExtResource("bd")]
sky_color = Color(0.30, 0.32, 0.34, 1)
tint = Color(0.62, 0.60, 0.62, 1)
far_scale = 0.10

[node name="GroundDirt" type="Sprite2D" parent="."]
position = Vector2(-600, 716)
script = ExtResource("tile")
tex_path = "res://assets/tilesets/ground_dirt.png"
width = 2800
height = 340

[node name="GroundTiles" type="Sprite2D" parent="."]
position = Vector2(-600, 684)
script = ExtResource("tile")
tex_path = "res://assets/tilesets/ground_dirt.png"
width = 2800
height = 36

[node name="Ground" type="StaticBody2D" parent="."]
position = Vector2(800, 700)

[node name="GroundShape" type="CollisionShape2D" parent="Ground"]
shape = SubResource("RectangleShape2D_ground")

[node name="GroundRect" type="ColorRect" parent="Ground"]
visible = false
offset_left = -800.0
offset_top = -16.0
offset_right = 800.0
offset_bottom = 16.0
color = Color(0.20, 0.16, 0.12, 1)

; 우측 절벽 placeholder
[node name="Cliff" type="ColorRect" parent="."]
offset_left = 1480.0
offset_top = 0.0
offset_right = 1600.0
offset_bottom = 684.0
color = Color(0.10, 0.10, 0.10, 1)

[node name="Player" parent="." instance=ExtResource("1_player")]
position = Vector2(160, 400)

[node name="Camera2D" type="Camera2D" parent="Player"]

[node name="default" type="Marker2D" parent="."]
position = Vector2(160, 400)
script = ExtResource("6_entry")

[node name="from_forest" type="Marker2D" parent="."]
position = Vector2(120, 400)
script = ExtResource("6_entry")

[node name="Boss" parent="." instance=ExtResource("2_boss")]
position = Vector2(1200, 640)

; 메인 퀘스트 boss_arena 단계 자동 진행
[node name="BossArenaTrigger" type="Area2D" parent="."]
collision_mask = 1
position = Vector2(220, 620)
script = ExtResource("7_trigger")
quest_id = "main_tiger_lord"
quest_stage = "boss_arena"
only_if_quest_active = "main_tiger_lord"

[node name="TriggerShape" type="CollisionShape2D" parent="BossArenaTrigger"]
shape = SubResource("RectangleShape2D_trigger")

; 두령의 일갈 — 아레나 깊숙이 들어서면 한 번만
[node name="BossIntroDialogue" type="Area2D" parent="."]
collision_mask = 1
position = Vector2(560, 620)
script = ExtResource("8_autodlg")
dialogue_path = "res://assets/dialogue/boss_arena_intro.json"
once_flag = "boss_intro_seen"

[node name="IntroShape" type="CollisionShape2D" parent="BossIntroDialogue"]
shape = SubResource("RectangleShape2D_trigger")

; 좌측: 숲으로 돌아가기
[node name="ExitToForest" type="Area2D" parent="."]
collision_mask = 1
position = Vector2(40, 620)
script = ExtResource("5_exit")
target_scene = "res://scenes/levels/Forest.tscn"
target_entry = &"from_boss"

[node name="ExitShape" type="CollisionShape2D" parent="ExitToForest"]
shape = SubResource("RectangleShape2D_exit")

[node name="ExitMark" type="ColorRect" parent="ExitToForest"]
