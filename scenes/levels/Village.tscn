[gd_scene load_steps=11 format=3]

; 마을(시작 허브) — 아트 없이 placeholder. 가로 1600px 폭에 한지 베이지 톤 배경.
; 좌측: 상점·집 placeholder + Villager NPC. 우측: 들판으로 가는 LevelExit.
; 새 게임 시 MainMenu 가 Village.tscn 으로 진입. TestLevel(들판)에서 좌측 LevelExit 로 되돌아옴.
; '떠돌이 상인' 은 NightOnly 노드 아래에 있어 밤(TimeManager.is_night)에만 등장.

[ext_resource type="PackedScene" path="res://scenes/player/Player.tscn" id="1_player"]
[ext_resource type="PackedScene" path="res://scenes/npc/Npc.tscn" id="2_npc"]
